// File: bos-workspace/backend-nestjs/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// BLOCK 0: SAAS MULTI-TENANCY
// ==========================================
model Tenant {
  id        Int      @id @default(autoincrement())
  name      String
  code      String   @unique // VD: "company_a", "company_b"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users        User[]
  entities     Entity[]
  records      Record[]
  workflows    Workflow[]
  attachments  Attachment[]
  notifications Notification[] // Quan hệ với hòm thư thông báo

  @@map("tenants")
}

// ==========================================
// BLOCK 1: AUTH & ORGANIZATION
// ==========================================
model User {
  id           Int        @id @default(autoincrement())
  email        String     @unique
  password     String
  fullName     String     @map("full_name")
  departmentId Int?       @map("department_id")
  roleId       Int?       @map("role_id")
  tenantId     Int?       @map("tenant_id") // Khóa ngoại Tenant
  status       String     @default("ACTIVE")
  userType     String     @default("INTERNAL") @map("user_type")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  department   Department? @relation(fields: [departmentId], references: [id])
  role         Role?       @relation(fields: [roleId], references: [id])
  tenant       Tenant?     @relation(fields: [tenantId], references: [id])
  instances    WorkflowInstance[]
  workflowLogs WorkflowLog[]
  participations WorkflowParticipant[]
  recordRevisions RecordRevision[]
  notifications Notification[] // Quan hệ với hòm thư thông báo

  @@map("users")
}

model Department {
  id          Int      @id @default(autoincrement())
  name        String
  parentId    Int?     @map("parent_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  parent      Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children    Department[] @relation("DepartmentHierarchy")
  users       User[]

  @@map("departments")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String
  permissions Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       User[]

  @@map("roles")
}

// ==========================================
// BLOCK 2: METADATA ENGINE & PRINT TEMPLATES
// ==========================================
model Entity {
  id              Int      @id @default(autoincrement())
  name            String
  code            String   @unique
  description     String?
  autoCodePattern String?  @map("auto_code_pattern")
  tenantId        Int?     @map("tenant_id") // Khóa ngoại Tenant
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant         Tenant?  @relation(fields: [tenantId], references: [id])
  fields         FieldDefinition[]
  records        Record[]
  workflows      Workflow[]
  printTemplates PrintTemplate[]

  @@map("entities")
}

model FieldDefinition {
  id          Int      @id @default(autoincrement())
  entityId    Int      @map("entity_id")
  name        String
  code        String
  type        String
  isRequired  Boolean  @default(false) @map("is_required")
  options     Json     @default("{}")
  orderIndex  Int      @default(0) @map("order_index")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  entity      Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, code])
  @@map("field_definitions")
}

model PrintTemplate {
  id          Int      @id @default(autoincrement())
  entityId    Int      @map("entity_id")
  name        String
  template    Json
  createdAt   DateTime @default(now()) @map("created_at")
  
  entity      Entity   @relation(fields: [entityId], references: [id])
  @@map("print_templates")
}

// ==========================================
// BLOCK 3: DYNAMIC DATA STORAGE & REVISIONS
// ==========================================
model Record {
  id          Int      @id @default(autoincrement())
  entityId    Int      @map("entity_id")
  recordCode  String?  @unique @map("record_code")
  data        Json     @default("{}")
  createdBy   Int      @map("created_by")
  tenantId    Int?     @map("tenant_id") // Khóa ngoại Tenant
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  entity      Entity   @relation(fields: [entityId], references: [id])
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  instances   WorkflowInstance[]
  revisions   RecordRevision[]
  attachments Attachment[]

  @@index([entityId])
  @@map("records")
}

model RecordRevision {
  id          Int      @id @default(autoincrement())
  recordId    Int      @map("record_id")
  userId      Int      @map("user_id")
  patchData   Json     @map("patch_data")
  createdAt   DateTime @default(now()) @map("created_at")

  record      Record   @relation(fields: [recordId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])

  @@index([recordId])
  @@map("record_revisions")
}

model Attachment {
  id          Int      @id @default(autoincrement())
  recordId    Int?     @map("record_id")
  tenantId    Int?     @map("tenant_id")
  fileName    String   @map("file_name")
  s3Key       String   @unique @map("s3_key")
  mimeType    String   @map("mime_type")
  fileSize    Int      @map("file_size")
  createdAt   DateTime @default(now()) @map("created_at")

  record      Record?  @relation(fields: [recordId], references: [id], onDelete: Cascade)
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])

  @@map("attachments")
}

// ==========================================
// BLOCK 5: NOTIFICATIONS (HỒM THƯ THÔNG BÁO)
// ==========================================
model Notification {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id") // Người nhận thông báo
  tenantId    Int?     @map("tenant_id") // SaaS Isolation
  title       String   // Tiêu đề (VD: "Yêu cầu phê duyệt phiếu")
  message     String   // Nội dung chi tiết
  isRead      Boolean  @default(false) @map("is_read") // Đã đọc hay chưa
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])

  @@map("notifications")
}

// ==========================================
// BLOCK 4: WORKFLOW & VERSIONING ENGINE
// ==========================================
model Workflow {
  id          Int      @id @default(autoincrement())
  entityId    Int      @map("entity_id")
  name        String
  description String?
  visibility  Json     @default("{}")
  tenantId    Int?     @map("tenant_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  entity      Entity   @relation(fields: [entityId], references: [id])
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  versions    WorkflowVersion[]

  @@map("workflows")
}

model WorkflowVersion {
  id          Int      @id @default(autoincrement())
  workflowId  Int      @map("workflow_id")
  version     Int      @default(1)
  status      String   @default("DRAFT")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  steps       WorkflowStep[]
  instances   WorkflowInstance[]

  @@unique([workflowId, version])
  @@map("workflow_versions")
}

model WorkflowStep {
  id                Int      @id @default(autoincrement())
  versionId         Int      @map("version_id")
  name              String
  stepType          String   @default("USER_TASK")
  permissions       Json     @default("{}")
  transitionRules   Json     @default("{}")
  orderIndex        Int      @default(0) @map("order_index")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  
  version           WorkflowVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  transitionsOut    WorkflowTransition[] @relation("FromStep")
  transitionsIn     WorkflowTransition[] @relation("ToStep")
  logs              WorkflowLog[]

  @@map("workflow_steps")
}

model WorkflowTransition {
  id              Int     @id @default(autoincrement())
  fromStepId      Int     @map("from_step_id")
  toStepId        Int     @map("to_step_id")
  conditionLogic  Json
  autoSkip        Boolean @default(false) @map("auto_skip")
  
  fromStep        WorkflowStep @relation("FromStep", fields: [fromStepId], references: [id])
  toStep          WorkflowStep @relation("ToStep", fields: [toStepId], references: [id])
  @@map("workflow_transitions")
}

model WorkflowInstance {
  id          Int      @id @default(autoincrement())
  versionId   Int      @map("version_id")
  recordId    Int      @map("record_id")
  currentStep Int      @map("current_step")
  status      String   @default("IN_PROGRESS")
  assigneeId  Int?     @map("assignee_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  version     WorkflowVersion @relation(fields: [versionId], references: [id])
  record      Record          @relation(fields: [recordId], references: [id])
  assignee    User?           @relation(fields: [assigneeId], references: [id])
  
  logs              WorkflowLog[]
  participants      WorkflowParticipant[]

  @@map("workflow_instances")
}

model WorkflowParticipant {
  id          Int    @id @default(autoincrement())
  instanceId  Int    @map("instance_id")
  userId      Int    @map("user_id")
  role        String
  
  instance    WorkflowInstance @relation(fields: [instanceId], references: [id])
  user        User             @relation(fields: [userId], references: [id])
  @@map("workflow_participants")
}

model WorkflowLog {
  id          Int      @id @default(autoincrement())
  instanceId  Int      @map("instance_id")
  stepId      Int?     @map("step_id")
  userId      Int?     @map("user_id")
  action      String
  comment     String?
  snapshot    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  instance    WorkflowInstance @relation(fields: [instanceId], references: [id])
  step        WorkflowStep?    @relation(fields: [stepId], references: [id])
  user        User?            @relation(fields: [userId], references: [id])
  @@map("workflow_logs")
}